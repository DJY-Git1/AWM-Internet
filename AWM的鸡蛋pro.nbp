    "content": {
        "data": "{\"formData\":null,\"sensorData\":null,\"textPanel\":{\"list\":[{\"title\":\"目的\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"font-family:宋体\\\"><span style=\\\"font-family:宋体\\\">认识惯性。</span></span></span></span></p>\\n\"},{\"title\":\"原理\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"font-family:宋体\\\"><span style=\\\"font-family:宋体\\\">一切物体都有保持原来运动状态不变的性质。</span></span></span></span></p>\"},{\"title\":\"器材\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"font-family:宋体\\\"><span style=\\\"color:#000000\\\"><span style=\\\"font-family:宋体\\\">装水的烧杯、鸡蛋、薄木板</span></span></span></span></span></p>\"},{\"title\":\"步骤\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"font-family:宋体\\\">1. <span style=\\\"font-family:宋体\\\">拖动薄木板放在烧杯上，鸡蛋放在薄木板上，且在烧杯正上方；</span></span></span></span></p>\\n\\n<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"font-family:宋体\\\">2.</span>&nbsp;<span style=\\\"font-family:宋体\\\"><span style=\\\"font-family:宋体\\\">快速抽出薄木板，观察现象。</span></span></span></span></p>\"},{\"title\":\"结论\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:Calibri\\\"><span style=\\\"background-color:#ffffff\\\"><span style=\\\"font-family:宋体\\\"><span style=\\\"color:#000000\\\"><span style=\\\"font-family:宋体\\\">一切物体总保持匀速直线运动状态或静止状态，除非作用在它上面的力迫使它改变这种状态。</span></span></span></span></span></span></p>\"},{\"title\":\"补充\",\"data\":\"<p style=\\\"text-align:justify\\\"><span style=\\\"font-size:28px\\\"><span style=\\\"font-family:&quot;Times New Roman&quot;\\\"><span style=\\\"background-color:#ffffff\\\"><span style=\\\"font-family:宋体\\\"><span style=\\\"color:#000000\\\"><span style=\\\"font-family:宋体\\\">物体无论受力还是不受力，运动还是静止都有惯性，惯性大小只与物体的质量有关。</span></span></span></span></span></span></p>\"}],\"x\":212,\"y\":50,\"width\":600,\"height\":565},\"phyData\":{\"properties\":{\"data\":{\"containsVipequ\":true,\"version\":5,\"SHOWEQUVALUE\":true,\"SHOW_FLAG_LABEL\":true,\"VOLUME\":1,\"COMP_MESS\":true,\"BTN_NAME\":true,\"RESOLUTION\":1,\"backgroundColorImg\":{\"colors\":{\"direction\":0,\"arr\":[\"#343941\"],\"style\":{\"background\":\"#343941\"}},\"textureSelected\":0},\"dataArr\":[{\"uid\":1780836355117,\"classname\":\"NbDesk\",\"cateid\":\"5\",\"positionX\":0,\"positionY\":0,\"rotation\":0,\"loadLevel\":5,\"notexture\":\"0\",\"ismecJoint\":false,\"isMechanics\":true,\"thisX\":-2734.010187217723,\"thisY\":3595.116112940347,\"fromEquTools\":true,\"material\":{\"density\":0.8,\"elasticity\":0,\"dynamicFriction\":1,\"staticFriction\":2,\"rollingFriction\":1},\"transform\":{\"a\":1,\"b\":0,\"c\":0,\"d\":1,\"tx\":0,\"ty\":0},\"currentScale\":{\"x\":1,\"y\":1},\"posx\":-2734.010187217723,\"posy\":3595.116112940347,\"allowRotation\":true},{\"uid\":1770775998837,\"classname\":\"Stonesg\",\"cateid\":\"5\",\"positionX\":0,\"positionY\":0,\"rotation\":2.6358787591993327,\"loadLevel\":5,\"notexture\":\"0\",\"ismecJoint\":false,\"isMechanics\":true,\"thisX\":4737.705793439206,\"thisY\":4972.5335575304725,\"fromEquTools\":true,\"material\":{\"density\":4.990230522965151,\"elasticity\":0.3,\"dynamicFriction\":0.5,\"staticFriction\":0.6,\"rollingFriction\":0.001},\"transform\":{\"a\":1,\"b\":0,\"c\":0,\"d\":1,\"tx\":0,\"ty\":0},\"currentScale\":{\"x\":1,\"y\":1},\"posx\":4737.705793439206,\"posy\":4972.5335575304725,\"allowRotation\":true,\"wetMl\":0,\"wetMass\":0,\"wetDensity\":0,\"isWet\":false,\"type\":0},{\"uid\":1770776197950,\"classname\":\"Stonesg\",\"cateid\":\"5\",\"positionX\":0,\"positionY\":0,\"rotation\":3.645288262539978,\"loadLev